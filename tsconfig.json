{
	"include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts", "playwright.config.ts", "e2e/**/*.ts", ".storybook/**/*.ts"],
	"exclude": ["convex/**/*"],
	"compilerOptions": {
		"target": "ES2022",
		"jsx": "react-jsx",
		"module": "ESNext",
		"baseUrl": ".",
		"paths": {
			"#/*": ["./src/*"],
			"@/*": ["./src/*"]
		},
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["vite/client", "node"],
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"allowJs": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true
	}
}
